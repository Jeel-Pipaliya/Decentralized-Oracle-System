# Network
RPC_URL=http://127.0.0.1:8545

# Contracts
ORACLE_CONTRACT=0xYourWeatherOracleAddress
INSURANCE_CONTRACT=0xYourCropInsuranceAddress

# Owner key used by backend for owner-only contract calls
OWNER_PRIVATE_KEY=0xYourOwnerPrivateKey

# Node keys (fallback to PRIVATE_KEY if omitted)
NODE1_PRIVATE_KEY=0xYourNode1PrivateKey
NODE2_PRIVATE_KEY=0xYourNode2PrivateKey
NODE3_PRIVATE_KEY=0xYourNode3PrivateKey
PRIVATE_KEY=0xOptionalFallbackPrivateKey

# Register script (comma separated)
ORACLE_NODE_ADDRESSES=0xNodeAddress1,0xNodeAddress2,0xNodeAddress3

# Weather API keys used by nodes
WEATHERAPI_KEY=your-weatherapi-key
OPENWEATHER_KEY=your-openweather-key

# Frontend
REACT_APP_API_BASE=http://localhost:3000
